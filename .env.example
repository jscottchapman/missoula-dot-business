# Anthropic — Claude Haiku for SEO audits
# Option A: Direct Anthropic API
ANTHROPIC_API_KEY=

# Option B: ngrok AI Gateway (credit-based cost cap, observability, failover)
# If set, these take precedence over ANTHROPIC_API_KEY
NGROK_AI_GATEWAY_URL=
NGROK_AI_GATEWAY_KEY=

# Mailtrap — transactional email (verify missoula.business domain)
MAILTRAP_API_KEY=

# Vercel KV (Upstash Redis) — rate limiting
# Auto-injected when you add KV storage in Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Kit.com — email drip sequence
KIT_API_KEY=
KIT_FORM_ID=
